# Server
PORT=3001
NODE_ENV=development

# LLM Provider: openai | claude
LLM_PROVIDER=openai

# OpenAI-compatible provider: OpenAI / Groq / compatible gateway
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_MODEL=your-model-name
# Leave empty for the default provider endpoint; fill it for compatible gateways.
OPENAI_BASE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=your-claude-model-name
# Leave empty for the official Anthropic endpoint; fill it for Anthropic-compatible gateways.
ANTHROPIC_BASE_URL=

# MySQL (default connection for demo)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
MYSQL_DATABASE=demo

# Audit
AUDIT_DB_PATH=./audit.db

# Security
API_KEY=your-api-key-here
